OPENROUTER_API_KEY=your_api_key_here
# Если не задать OPENROUTER_MODEL_CHEAP и OPENROUTER_MODEL_SMART, оба берут значение OPENROUTER_MODEL (часто дорого).
OPENROUTER_MODEL=openai/gpt-4o-mini
# Рекомендуемая пара для каскада ModelRouter: дешёвый массовый шаг + умная модель при эскалации.
# Список имён: https://openrouter.ai/models — неверный slug даёт 404 «No endpoints found for …».
OPENROUTER_MODEL_CHEAP=openai/gpt-4o-mini
OPENROUTER_MODEL_SMART=google/gemini-2.5-flash
AGENT_MAX_TOTAL_STEPS=80
AGENT_MAX_SUBTASK_STEPS=25
# Максимум подзадач в одном плане (промпт LLM-планировщика + обрезка ответа; значение 1–50).
AGENT_PLANNER_MAX_SUBTASKS=6
# Температура только для LLM-планировщика (0 = детерминированнее, меньше «лишних» шагов; поднимать обычно не нужно).
AGENT_PLANNER_TEMPERATURE=0
AGENT_SMART_COOLDOWN_STEPS=2
AGENT_PROMPT_MAX_OBSERVATION_ITEMS=70
AGENT_PROMPT_MAX_TEXT_FIELD_LEN=80
AGENT_ACTOR_RESPONSE_MAX_TOKENS=300
# План теперь всегда режется LLM-планировщиком оркестратора (normalizer в runtime не используется).
# AGENT_USE_LLM_PLANNER оставлен только для обратной совместимости и игнорируется.
# Сколько подряд «капча → wait» допускаем до состояния BLOCKED_CAPTCHA.
AGENT_CAPTCHA_MAX_CONSECUTIVE_WAIT=20
# Повторы chat.completions при обрыве сети / 5xx (не при ошибке парсинга JSON действия).
AGENT_LLM_TRANSPORT_MAX_RETRIES=3
# После успешного плана — короткий LLM-вопрос «достигнута ли цель» (доп. запрос).
AGENT_GOAL_VERIFY_LLM=false
# Если verify вернул satisfied=false: true = завершить PARTIAL вместо ERROR (осторожно: итог может быть неполным).
AGENT_GOAL_VERIFY_FAIL_SOFT=false
# При лимите шагов подзадачи помечать её выполненной и идти дальше (риск недовыполнения цели).
AGENT_CONTINUE_AFTER_SUBTASK_LIMIT=false
# Окно браузера: false = видимый Chromium (по умолчанию), true = headless (сервер/CI).
AGENT_BROWSER_HEADLESS=false
# Layout viewport для нового контекста Playwright (адаптив сайта зависит от ширины/высоты в px). Ограничения в load_app_settings.
AGENT_BROWSER_VIEWPORT_WIDTH=1440
AGENT_BROWSER_VIEWPORT_HEIGHT=900
# Подключение к УЖЕ запущенному Chromium по CDP (новый процесс не стартует). Пример: http://127.0.0.1:9222
# Запуск браузера вручную: google-chrome --remote-debugging-port=9222  (или chromium с тем же флагом)
# AGENT_BROWSER_CDP_URL=http://127.0.0.1:9222
# Микро LLM self-check после успешного шага: достигнута ли цель текущей подзадачи (доп. дешёвый запрос).
AGENT_SUBTASK_GOAL_SELF_CHECK_LLM=false
# Каждый шаг актёра: скрин viewport + список a11y в одну multimodal-сессию (сверка видимого и дерева). false — только текстовый промпт.
# Нужны модели с поддержкой изображений в chat (иначе OpenRouter вернёт ошибку на шаге с картинкой).
AGENT_OBSERVATION_FUSION_MULTIMODAL=true
AGENT_PRICE_DEFAULT_INPUT_PER_1M=0
AGENT_PRICE_DEFAULT_OUTPUT_PER_1M=0
AGENT_PRICE_CHEAP_INPUT_PER_1M=0.8
AGENT_PRICE_CHEAP_OUTPUT_PER_1M=4
AGENT_PRICE_SMART_INPUT_PER_1M=3
AGENT_PRICE_SMART_OUTPUT_PER_1M=15
OPENROUTER_HTTP_REFERER=https://your-site.example
OPENROUTER_X_TITLE=SyncJarvis Agent

